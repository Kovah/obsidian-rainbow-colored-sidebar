{
	"name": "rainbow-colored-sidebar",
	"version": "1.5.3",
	"description": "Automatically color your sidebar like a rainbow. No configuration needed. 18 themes included.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"preview": "node scripts/generate-scheme-preview.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"rainbow",
		"colored",
		"sidebar"
	],
	"author": "Kevin Woblick <mail@woblick.dev>",
	"license": "MIT",
	"engines": {
		"node": "24.x"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"esbuild": "^0.28.1",
		"esbuild-sass-plugin": "^3.3",
		"obsidian": "latest",
		"tslib": "^2.8",
		"typescript": "^6.0.3"
	}
}
